{
	"name": "free-json-formatter",
	"version": "0.2.1",
	"description": "Fast, private JSON viewer for the browser. No telemetry, no external requests, minimal permissions.",
	"license": "MIT",
	"author": "andret2344",
	"homepage": "https://github.com/andret2344/free-json-formatter",
	"repository": {
		"type": "git",
		"url": "https://github.com/andret2344/free-json-formatter.git"
	},
	"bugs": {
		"url": "https://github.com/andret2344/free-json-formatter/issues"
	},
	"keywords": [
		"json",
		"formatter",
		"viewer",
		"browser-extension",
		"chrome-extension",
		"firefox-addon",
		"manifest-v3",
		"typescript"
	],
	"type": "module",
	"packageManager": "yarn@1.22.22",
	"scripts": {
		"build": "node scripts/build.mjs",
		"build:chromium": "node scripts/build.mjs --target=chromium",
		"build:firefox": "node scripts/build.mjs --target=firefox",
		"watch": "node scripts/build.mjs --watch --target=chromium",
		"icons": "node scripts/icons.mjs",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@playwright/test": "^1.61.1",
		"@types/chrome": "^0.2.2",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"esbuild": "^0.28.1",
		"jsdom": "^29.1.1",
		"lucide": "^1.24.0",
		"sharp": "^0.35.3",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	}
}
